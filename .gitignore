# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.uid

# Importados automaticamente (se regeneran)
.import/
export.cfg
export_presets.cfg

# Mono / C# (si aplica)
.mono/
data_*/
mono_crash.*.json

# Builds
builds/
*.apk
*.aab
*.ipa
*.exe
*.x86_64
*.app

# Logs (runtime — change every game run)
*.log

# Batch files (generated at runtime)
*.bat

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
*.swp
*~
