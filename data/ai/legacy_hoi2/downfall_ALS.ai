invasion = {
  	#for evaluating specific province target.
	base 		= 0.1	# Relative modifier. (lower = specific targets much more important.)
	random 		= 20.0	# How big a random range.  (1.0 = 1%)
	coastal 	= 0.1	# increase to avoid coastal forts more.
	beach 	= 0.1	# higher, avoid worst beaches.
	distance 	= 0.01	# higher = avoid long distance.
	pocket 		= 0.1   # prioritise pockets, ie provinces with no adjacent controlled by same.
	island 		= 0.1   # prioritise taking pure islands.
	enemy 		= 0.01   # higher = much more vary of troops in province.
	adjacentenemy 	= 0.005   # higher = much more vary of troops nearby
	air_base	= 0.1   # add this priority for air bases within adjacentenemy
	naval_base	= 0.1	# add this priority for naval bases within adjacentenemy
	air_support	= 5.0   # add this priority for beaches within reach of air_bases
	help_allies = yes
	invasion = yes
	ignore = no

	redirect 	= priority # priority refers to targets in the AI file,

